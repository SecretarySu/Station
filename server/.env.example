# ============================================
# Veinashe Bags - 飞书多维表对接配置
# ============================================
# 请将此文件复制为 .env 并填入真实值
# cp .env.example .env

# ----- 飞书应用凭证 -----
# 在飞书开放平台 → 你的应用 → 凭证与基础信息 中获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- 飞书多维表标识 -----
# 多维表 URL 格式: https://xxx.feishu.cn/base/xxxxx?table=tblxxxxx
#   app_token  = base/ 后面的那串字符
#   table_id   = table= 后面的那串字符
FEISHU_APP_TOKEN=bascnxxxxxxxxxxxx
FEISHU_TABLE_ID=tblxxxxxxxxxxxx

# ----- 服务器配置 -----
PORT=3001

# ----- 安全（可选） -----
# 如果设置了 API_KEY，前端提交时必须在 Header 中携带 X-API-Key
# API_KEY=your-secret-api-key
